# Dockerfile.mcp
# MCP Server container — exposes database tools + code execution + report generation

FROM python:3.12-slim

WORKDIR /app

# Create reports directory
RUN mkdir -p /app/reports

# Install MCP server dependencies
COPY requirements.mcp.txt .
RUN pip install --no-cache-dir -r requirements.mcp.txt

# Copy the MCP server code and env
COPY mcp_server.py .
COPY .env .

# MCP SSE transport listens on port 8000 by default
EXPOSE 8000

CMD ["python", "mcp_server.py"]
