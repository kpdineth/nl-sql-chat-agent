# ============================================
# NL-SQL Chat System — Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#
# NEVER commit .env to git! It contains your secret API keys.

# --- Database (used by containers internally) ---
DATABASE_URL=postgresql://admin:secret123@localhost:5433/shopdb
DATABASE_URL_READONLY=postgresql://readonly_user:readonly123@localhost:5433/shopdb

# --- Anthropic API Key (required for Claude AI) ---
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# --- MCP Server URL (internal Docker network, don't change) ---
MCP_SERVER_URL=http://mcp-server:8000

# --- ngrok Auth Token (required for tunnel) ---
# Get yours at: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-token-here
